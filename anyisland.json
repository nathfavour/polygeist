{
  "name": "polygeist",
  "version": "1.0.0",
  "description": "Sovereign multi-agent control plane and orchestration daemon",
  "repository": "github.com/nathfavour/polygeist",
  "install_dir": "~/.local/bin",
  "build": {
    "toolchain": "shell",
    "steps": [
      "git submodule update --init --recursive",
      "go build -ldflags '-s -w' -o polygeist ./cmd/polygeist"
    ],
    "bin": "polygeist"
  },
  "features": {
    "track_submodules": true,
    "recursive_install": true
  },
  "runtime": {
    "daemon": true,
    "pulse": true,
    "dependencies": ["git", "go"]
  }
}
